// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "gutter": {
    "line_numbers": false,
  },
  "buffer_font_family": "Berkeley Mono SemiCondensed",
  "agent": {
    "default_model": {
      "provider": "openai-subscribed",
      "model": "gpt-5.5",
      "enable_thinking": true,
      "effort": "medium",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "agent_servers": {
    "codex-acp": {
      "default_config_options": {
        "reasoning_effort": "xhigh",
      },
      "type": "registry",
    },
  },
  "base_keymap": "Emacs",
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "ui_font_size": 16,
  "buffer_font_size": 16.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Solarized Dark Custom",
  },
  "terminal": {
    "font_family": "Berkeley Mono SemiCondensed",
    "font_size": 16,
  },
}
