# -*- mode: conf-unix -*-
[init]
        defaultBranch = main
[color]
        ui = true
[user]
        name = Bradley Wright
        email = brad@intranation.com
[alias]
        co = checkout
        st = status -sb
        l = log --decorate --name-status
        graph = log --graph --format='%Cred%h%Creset %s <%Cgreen%ae>'
        lines = diff --stat
        amend = commit --amend -C HEAD
        words = diff --word-diff
        prune-branches = !git branch -vv | grep ': gone]' | awk '{print $1}' | xargs git branch -d
[branch]
        autosetuprebase = always
[push]
        default = tracking
        autoSetupRemote = true
[fetch]
        prune = true # requires Git 1.8.5 or higher
[commit]
        verbose = true

[core]
        excludesfile = ~/.gitignore
        pager = delta
        editor = nvim +star
[interactive]
        diffFilter = delta --color-only
[delta]
        navigate = true
        side-by-side = true
        line-numbers = true
        syntax-theme = Catppuccin Mocha
[merge]
        conflictstyle = zdiff3
