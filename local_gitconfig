# -*- mode: conf-unix -*-
[init]
        defaultBranch = main
[color]
        ui = true
[user]
        name = Bradley Wright
        email = brad@intranation.com
[alias]
        co = checkout
        st = status -sb
        l = log --decorate --name-status
        graph = log --graph --format='%Cred%h%Creset %s <%Cgreen%ae>'
        lines = diff --stat
        amend = commit --amend -C HEAD
        words = diff --word-diff
        prune-branches = !git branch -vv | grep ': gone]' | awk '{print $1}' | xargs git branch -d
[branch]
        autosetuprebase = always
[push]
        default = tracking
        autoSetupRemote = true
[fetch]
        prune = true # requires Git 1.8.5 or higher
[commit]
        verbose = true

[core]
        excludesfile = ~/.gitignore
        pager = delta
        editor = nvim +star
[interactive]
        diffFilter = delta --color-only
[delta]
        navigate = true
        side-by-side = true
        line-numbers = true
        syntax-theme = Solarized (dark)
        minus-style = syntax "#3a1010"
        minus-emph-style = syntax "#6b1515"
        minus-empty-line-marker-style = normal "#3a1010"
        plus-style = syntax "#0f3520"
        plus-emph-style = syntax "#1a5c2a"
        plus-empty-line-marker-style = normal "#0f3520"
        line-numbers-minus-style = red black
        line-numbers-plus-style = green black
        line-numbers-zero-style = brightgreen black
[merge]
        conflictstyle = zdiff3
