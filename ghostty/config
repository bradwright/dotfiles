# -*- mode: conf; -*-

# Theme and Fonts
theme = solarized-dark-custom
font-family = Berkeley Mono Semicondensed
font-size = 16
font-thicken = true

# Window & Appearance — dark chrome to match solarized dark
window-padding-x = 12
window-padding-y = 4
window-theme = dark
macos-titlebar-style = tabs

# Cursor
cursor-style = block
cursor-style-blink = true

# Solarized palette — keep bold from remapping to bright, which would
# break the carefully designed base tones
bold-is-bright = false

# Selection — invert for clear visibility against the muted solarized tones
selection-invert-fg-bg = true

# Use fish as the default shell inside Ghostty without changing the
# system login shell (which stays zsh for compatibility).
command = /opt/homebrew/bin/fish

# Shell Integration
shell-integration = detect
shell-integration-features = cursor,sudo,title,ssh-env,ssh-terminfo

# Mouse & Clipboard
mouse-hide-while-typing = true

# Performance & Rendering
scrollback-limit = 10000
window-vsync = true

# Splits — overlay unfocused splits with solarized base02 so the active
# pane is clearly distinguishable
unfocused-split-opacity = 0.7
unfocused-split-fill = #073642

# Quality of Life
confirm-close-surface = true
window-save-state = always
auto-update = check
quick-terminal-position = top
quick-terminal-size = 40%

# Keybindings
keybind = shift+enter=text:\x1b\r
keybind = alt+backspace=text:\x17
keybind = global:ctrl+backquote=toggle_quick_terminal
