# Config syntax crash course
# ==========================
# # The config file consists of simple key-value pairs,
# # separated by equals signs.
# font-family = Iosevka
# window-padding-x = 2
#
# # Spacing around the equals sign does not matter.
# # All of these are identical:
# key=value
# key= value
# key =value
# key = value
#
# # Any line beginning with a # is a comment. It's not possible to put
# # a comment after a config option, since it would be interpreted as a
# # part of the value. For example, this will have a value of "#123abc":
# background = #123abc
#
# # Empty values are used to reset config keys to default.
# key =
#
# # Some config options have unique syntaxes for their value,
# # which is explained in the docs for that config option.
# # Just for example:
# resize-overlay-duration = 4s 200ms

# Theme and Fonts
theme = Catppuccin Mocha
font-family = Berkeley Mono Semicondensed
font-size = 16
font-thicken = true

# Window & Appearance — dark chrome to match Catppuccin Mocha
window-padding-x = 12
window-padding-y = 4
window-theme = ghostty
macos-titlebar-style = tabs

# Cursor
cursor-style = block
cursor-style-blink = true

# Selection — invert for clear visibility against the muted Catppuccin tones
selection-invert-fg-bg = true

# Use fish as the default shell inside Ghostty without changing the
# system login shell (which stays zsh for compatibility).
command = /opt/homebrew/bin/fish

# Shell Integration
shell-integration = detect
shell-integration-features = cursor,sudo,title

# Mouse & Clipboard
mouse-hide-while-typing = true

# Performance & Rendering
scrollback-limit = 10000
window-vsync = true

# Splits — overlay unfocused splits with Catppuccin Mocha "Crust" so the
# active pane is clearly distinguishable
unfocused-split-opacity = 0.7
unfocused-split-fill = #11111b

# Quality of Life
confirm-close-surface = true
window-save-state = always
auto-update = check

# Keybindings
keybind = shift+enter=text:\x1b\r
keybind = alt+backspace=text:\x17
